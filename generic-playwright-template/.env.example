# MyApp Environment Configuration
# Copy this file to .env and update with your actual values

# Application URLs
MYAPP_APP_URL=https://test.example.com/MyApp/
MYAPP_ADMINPORTAL_URL=https://test.example.com/AdminPortal/

# Test User Credentials
MYAPP_ADMIN_USER=admin@example.com
MYAPP_ADMIN_PASS=admin123

MYAPP_MANAGER_USER=manager@example.com
MYAPP_MANAGER_PASS=manager123

MYAPP_OPERATOR_USER=operator@example.com
MYAPP_OPERATOR_PASS=operator123

MYAPP_VIEWER_USER=viewer@example.com
MYAPP_VIEWER_PASS=viewer123

# Optional: Hold browser open after tests (for visual debugging)
# MYAPP_HOLD_MS=5000